# ─── App ────────────────────────────────────────────
APP_ENV=development                         # development | production
SECRET_KEY=your-very-secret-jwt-key-here    # change this!
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── Database ────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aidocplatform

# ─── Azure Blob Storage ───────────────────────────────
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
AZURE_BLOB_CONTAINER_NAME=aidocplatform

# ─── Azure Document Intelligence ──────────────────────
AZURE_DI_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com/
AZURE_DI_KEY=your-azure-di-key-here

# ─── Gemini LLM ───────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-pro

# ─── LLM Provider ─────────────────────────────────────
LLM_PROVIDER=gemini                         # gemini | ollama (Phase 2)
OLLAMA_URL=http://localhost:11434           # Only needed if LLM_PROVIDER=ollama
OLLAMA_MODEL=llama3
